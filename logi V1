function onAceChange(i, val) {
  document.getElementById(`ace_oui_${i}`).classList.toggle('active', val === 'Oui');
  document.getElementById(`ace_non_${i}`).classList.toggle('active', val === 'Non');
  updateACEScore();
  updateProgress();
}

function onAdultChange(i, val) {
  document.getElementById(`adult_oui_${i}`).classList.toggle('active', val === 'Oui');
  document.getElementById(`adult_non_${i}`).classList.toggle('active', val === 'Non');
  updateAdultScore();
  updateProgress();
}

function updateACEScore() {
  let score = 0;
  aceItems.forEach((_, i) => {
    const checked = document.querySelector(`input[name="ace_${i}"]:checked`);
    if (checked && checked.value === 'Oui') score++;
  });
  document.getElementById('aceScoreDisplay').textContent = `${score} / 13`;
  return score;
}

function updateAdultScore() {
  let score = 0;
  adultItems.forEach((_, i) => {
    const checked = document.querySelector(`input[name="adult_${i}"]:checked`);
    if (checked && checked.value === 'Oui') score++;
  });
  document.getElementById('adultScoreDisplay').textContent = `${score} / 21`;
  return score;
}

function updateCPSScores() {
  const axeMap = { 'COGNITIVE': [], 'ÉMOTIONNELLE': [], 'SOCIALE': [] };
  cpsItems.forEach((item, i) => {
    const checked = document.querySelector(`input[name="cps_${i}"]:checked`);
    if (checked) axeMap[item.axe].push(parseInt(checked.value));
  });
  const avg = arr => arr.length ? (arr.reduce((a, b) => a + b, 0) / arr.length).toFixed(1) : '—';
  document.getElementById('cpsCogDisplay').textContent = avg(axeMap['COGNITIVE']) + (axeMap['COGNITIVE'].length ? '/5' : '');
  document.getElementById('cpsEmoDisplay').textContent = avg(axeMap['ÉMOTIONNELLE']) + (axeMap['ÉMOTIONNELLE'].length ? '/5' : '');
  document.getElementById('cpsSocDisplay').textContent = avg(axeMap['SOCIALE']) + (axeMap['SOCIALE'].length ? '/5' : '');
  updateProgress();
  return axeMap;
}

// ======== PROGRESS ========

function setupProgress() {
  document.getElementById('mainForm').addEventListener('change', updateProgress);
}

function updateProgress() {
  const total = 3 + aceItems.length + adultItems.length + cpsItems.length;
  let filled = 0;
  if (document.querySelector('input[name="q1"]:checked')) filled++;
  if (document.querySelector('input[name="q2type"]:checked')) filled++;
  if (document.getElementById('patientId').value.trim()) filled++;
  aceItems.forEach((_, i) => { if (document.querySelector(`input[name="ace_${i}"]:checked`)) filled++; });
  adultItems.forEach((_, i) => { if (document.querySelector(`input[name="adult_${i}"]:checked`)) filled++; });
  cpsItems.forEach((_, i) => { if (document.querySelector(`input[name="cps_${i}"]:checked`)) filled++; });
  const pct = Math.round((filled / total) * 100);
  document.getElementById('progressBar').style.width = pct + '%';
  document.getElementById('progressLabel').textContent = `Progression : ${pct} %`;
}

document.addEventListener('input', updateProgress);

// ======== COLLECT DATA ========

function collectData() {
  const d = {};

  // Identifiant
  d.patientId = document.getElementById('patientId').value.trim();
  d.datePassation = document.getElementById('datePassation').value;

  // Section 1
  const q1 = document.querySelector('input[name="q1"]:checked');
  d.dureeSymptomes = q1 ? q1.value : 'Non renseigné';
  const q2 = document.querySelector('input[name="q2type"]:checked');
  d.diagnostic = q2 ? q2.value : 'Non renseigné';
  d.diagnosticDetail = document.getElementById('q2text').value;
  d.gestionDouleur = document.getElementById('q3').value;
  d.infoImportantes = document.getElementById('infoImportantes').value;

  // EPICES
  d.epicesScore = document.getElementById('epicesScore').value;
  d.epicesInterp = document.getElementById('epicesInterp').value;

  // ACE
  let aceScore = 0;
  const aceDetails = [];
  aceItems.forEach((item, i) => {
    const checked = document.querySelector(`input[name="ace_${i}"]:checked`);
    const val = checked ? checked.value : 'Non répondu';
    const comment = document.querySelector(`input[name="ace_comment_${i}"]`).value;
    if (val === 'Oui') aceScore++;
    aceDetails.push(`${item.cat} : ${val}${comment ? ' ('+comment+')' : ''}`);
  });
  d.aceScore = aceScore;
  d.aceDetails = aceDetails.join('\n');

  // ADULT
  let adultScore = 0;
  const adultDetails = [];
  adultItems.forEach((item, i) => {
    const checked = document.querySelector(`input[name="adult_${i}"]:checked`);
    const val = checked ? checked.value : 'Non répondu';
    if (val === 'Oui') adultScore++;
    adultDetails.push(`${item.ref}. ${item.type} : ${val}`);
  });
  d.adultScore = adultScore;
  d.adultDetails = adultDetails.join('\n');

  // CPS
  const axeMap = { 'COGNITIVE': [], 'ÉMOTIONNELLE': [], 'SOCIALE': [] };
  const cpsDetails = [];
  let cpsAlerts = [];
  cpsItems.forEach((item, i) => {
    const checked = document.querySelector(`input[name="cps_${i}"]:checked`);
    const val = checked ? parseInt(checked.value) : null;
    if (val !== null) axeMap[item.axe].push(val);
    cpsDetails.push(`${item.label} : ${val !== null ? val+'/5' : 'Non répondu'}`);
  });
  const avg = arr => arr.length ? (arr.reduce((a, b) => a + b, 0) / arr.length) : null;
  const cogAvg = avg(axeMap['COGNITIVE']);
  const emoAvg = avg(axeMap['ÉMOTIONNELLE']);
  const socAvg = avg(axeMap['SOCIALE']);

  d.cpsCog = cogAvg !== null ? cogAvg.toFixed(1) : '—';
  d.cpsEmo = emoAvg !== null ? emoAvg.toFixed(1) : '—';
  d.cpsSoc = socAvg !== null ? socAvg.toFixed(1) : '—';
  d.cpsDetails = cpsDetails.join('\n');

  // Alerts CPS
  const fragile = v => v !== null && v <= 2;
  const zone = v => v !== null && v > 2 && v <= 3;
  const ressource = v => v !== null && v > 3;
  const interp = v => v === null ? '—' : v <= 2 ? '⚠️ Fragilité' : v <= 3 ? '⚡ Zone intermédiaire' : '✅ Ressource';
  d.cpsCogInterp = interp(cogAvg);
  d.cpsEmoInterp = interp(emoAvg);
  d.cpsSocInterp = interp(socAvg);

  // Items faibles CPS
  let itemsFaibles = [];
  let totalFaibles = 0;
  cpsItems.forEach((item, i) => {
    const checked = document.querySelector(`input[name="cps_${i}"]:checked`);
    const val = checked ? parseInt(checked.value) : null;
    if (val !== null && val <= 2) { itemsFaibles.push(item.label); totalFaibles++; }
  });
  d.cpsItemsFaibles = itemsFaibles.join(', ') || 'Aucun';
  d.cpsTotalFaibles = totalFaibles;

  // Orientation suggérée
  let orientations = [];
  if (fragile(cogAvg)) orientations.push('TCC axe cognitif (impulsivité ou rigidité), DBT/STAIR modules cognitifs');
  if (fragile(emoAvg)) orientations.push('DBT module régulation émotionnelle, STAIR/ESTAIR phase 1');
  if (fragile(socAvg)) orientations.push('Entraînement habiletés sociales, assertivité, modules interpersonnels STAIR');
  if (totalFaibles >= 4) orientations.push('⚠️ Vulnérabilité globale : évaluation psychologique approfondie recommandée');
  d.orientations = orientations.length ? orientations.join('\n') : 'Aucune fragilité majeure détectée';

  return d;
}

