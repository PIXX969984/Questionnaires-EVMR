    patient_id: d.patientId,
    date: d.datePassation,
    subject: `[DPPC] Questionnaire — Patient ${d.patientId} — ${d.datePassation}`,
    body: body,
    ace_score: d.aceScore + ' / 13',
    cps_cog: d.cpsCog + '/5 ' + d.cpsCogInterp,
    cps_emo: d.cpsEmo + '/5 ' + d.cpsEmoInterp,
    cps_soc: d.cpsSoc + '/5 ' + d.cpsSocInterp,
    orientations: d.orientations,
  }).then(() => {
    document.getElementById('mainForm').style.display = 'none';
    document.querySelector('.intro-box').style.display = 'none';
    document.querySelector('.progress-wrap').style.display = 'none';
    document.querySelector('.progress-label').style.display = 'none';
    document.getElementById('successScreen').style.display = 'block';
  }).catch(err => {
    console.error(err);
    // Fallback : afficher le récapitulatif pour copie manuelle
    btn.disabled = false;
    btn.textContent = 'Envoyer mes réponses';
    showFallback(body, praticienEmail);
  });
}

function showFallback(body, email) {
  const existing = document.getElementById('fallbackPanel');
  if (existing) existing.remove();
  const div = document.createElement('div');
  div.id = 'fallbackPanel';
  div.style.cssText = 'background:#fff;border:2px solid var(--rust);border-radius:12px;padding:20px;margin-top:20px;';
  div.innerHTML = `
    <p style="color:var(--rust);font-weight:600;margin-bottom:12px;">⚠️ L'envoi automatique n'a pas fonctionné. EmailJS n'est pas encore configuré.</p>
    <p style="font-size:13px;color:#555;margin-bottom:12px;">Copiez le récapitulatif ci-dessous et envoyez-le manuellement à <strong>${email}</strong> :</p>
    <textarea readonly style="width:100%;height:300px;font-size:12px;font-family:monospace;border:1px solid #ddd;border-radius:6px;padding:10px;">${body}</textarea>
    <button onclick="navigator.clipboard.writeText(document.querySelector('#fallbackPanel textarea').value).then(()=>alert('Copié !'))" style="margin-top:10px;background:var(--teal);color:#fff;border:none;border-radius:6px;padding:9px 20px;font-family:'DM Sans',sans-serif;font-size:13px;cursor:pointer;">Copier le récapitulatif</button>
  `;
  document.querySelector('.submit-wrap').after(div);
  div.scrollIntoView({ behavior: 'smooth' });
}

// Radio style
document.addEventListener('change', e => {
  if (e.target.type === 'radio') {
    const group = e.target.closest('.radio-group');
    if (group) {
      group.querySelectorAll('.radio-option').forEach(opt => opt.classList.remove('selected'));
      e.target.closest('.radio-option')?.classList.add('selected');
    }
  }
});

</script>
</body>
</html>
